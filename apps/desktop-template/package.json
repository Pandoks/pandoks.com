{
  "name": "@pandoks.com/desktop-template",
  "productName": "Pandoks Desktop Template",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "portless run --name desktop-template vite dev",
    "build": "vite build",
    "preview": "portless run --name desktop-template-preview vite preview",
    "package": "vite build && electron-forge package",
    "make": "vite build && electron-forge make",
    "publish": "electron-forge publish",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "shadcn": "pnpm dlx shadcn-svelte@latest add -c ../../packages/svelte"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^2.1.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "electron": "^42.2.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@pandoks.com/svelte": "workspace:*",
    "electron-squirrel-startup": "^1.0.1"
  }
}
