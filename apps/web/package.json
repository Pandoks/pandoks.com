{
  "name": "@pandoks.com/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "prebuild": "vite-node --options.transformMode.ssr='/.*' ./src/lib/prebuild.ts",
    "postbuild": "vite-node --options.transformMode.ssr='/.*' ./src/lib/postbuild.ts",
    "sync:notion": "vite-node --options.transformMode.ssr='/.*' ./src/lib/notion.ts",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "shadcn": "pnpm dlx shadcn-svelte@latest add -c ../../packages/svelte"
  },
  "dependencies": {
    "@pandoks.com/svelte": "workspace:*",
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "@notionhq/client": "^5.18.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/enhanced-img": "^0.10.4",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/subset-font": "^2.3.0",
    "jsdom": "^28.1.0",
    "node-html-parser": "^7.1.0",
    "sharp": "^0.34.5",
    "subset-font": "^2.5.0",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-node": "^5.3.0",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.1.4"
  }
}
