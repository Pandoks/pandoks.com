{
  "name": "@pandoks.com/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "portless run --name web vite dev",
    "build": "vite build",
    "preview": "portless run --name web-preview vite preview",
    "sync:notion": "node ./scripts/notion.ts",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "shadcn": "pnpm dlx shadcn-svelte@latest add -c ../../packages/svelte"
  },
  "dependencies": {
    "@pandoks.com/svelte": "workspace:*",
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "@notionhq/client": "^5.22.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/enhanced-img": "^0.10.4",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/subset-font": "^2.3.0",
    "jsdom": "^29.1.1",
    "node-html-parser": "^7.1.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "subset-font": "^2.5.0",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.1.7"
  }
}
