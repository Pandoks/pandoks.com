# NOTE: You need to create a .env.<dev-stage (pandoks)> and a .env.production file for both stages
# If you use a .env file, it will override everything and you'll use the same .env for all stages
# OVH API credentials are different for each stage

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DEFAULT_ACCOUNT_ID=

OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=
# Existing non-secret Public Cloud project ID; not an OVH API credential
OVH_CLOUD_PROJECT_SERVICE=

TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=

GITHUB_TOKEN=

# Temporary exact Pulumi logical-name override for the documented two-deploy
# production scale-down; this is not an OVH service ID or credential
OVH_UNPROTECTED_NODE_LOGICAL_NAME=
