{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":semanticCommits", "group:allNonMajor", "group:allDigest"],
  "labels": ["dependencies"],
  "assignees": ["pandoks"],
  "minimumReleaseAge": "7 days",
  "dependencyDashboardTitle": "[renovate] 🤖 outdated dependencies",
  "dependencyDashboardLabels": ["dependencies"],
  "dependencyDashboardAutoclose": false,
  "dependencyDashboardOSVVulnerabilitySummary": "unresolved",
  "osvVulnerabilityAlerts": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0,
  "rangeStrategy": "pin",
  "postUpdateOptions": ["pnpmDedupe", "gomodTidy"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Keep the `go` directive in go.work in sync (Renovate's gomod manager only handles go.mod)",
      "managerFilePatterns": ["/(^|/)go\\.work$/"],
      "matchStrings": ["(^|\\n)go (?<currentValue>[\\d.]+)\\s*(\\n|$)"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version",
      "versioningTemplate": "go-mod-directive"
    },
    {
      "customType": "regex",
      "description": "Pin kubectl in the argocd image by version + SHA256 (binary fetched from dl.k8s.io, not a base image)",
      "managerFilePatterns": ["/(^|/)packages/argocd/Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)\\s+ARG KUBECTL_VERSION=(?<currentValue>v[\\d.]+)\\s+ARG KUBECTL_SHA256=(?<currentDigest>[a-f0-9]{64})"
      ],
      "versioningTemplate": "semver",
      "currentValueTemplate": "{{{currentValue}}}",
      "autoReplaceStringTemplate": "# renovate: datasource={{{datasource}}} depName={{{depName}}}\nARG KUBECTL_VERSION={{{newValue}}}\nARG KUBECTL_SHA256={{{newDigest}}}"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["helm-values", "helmv3"],
      "groupName": "helm charts"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "schedule": ["at any time"]
  }
}
