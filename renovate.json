{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":preserveSemverRanges",
    ":semanticCommits",
    "group:allNonMajor",
    "group:allDigest",
    "customManagers:dockerfileVersions"
  ],
  "labels": ["dependencies"],
  "assignees": ["pandoks"],
  "minimumReleaseAge": "7 days",
  "dependencyDashboardTitle": "[renovate] 🤖 outdated dependencies (DON'T DELETE)",
  "dependencyDashboardLabels": ["dependencies"],
  "dependencyDashboardOSVVulnerabilitySummary": "unresolved",
  "osvVulnerabilityAlerts": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0,
  "postUpdateOptions": ["pnpmDedupe", "gomodTidy"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Sync the `go` directive in go.work when go.mod is bumped (Renovate's gomod manager only handles go.mod)",
      "managerFilePatterns": ["/(^|/)go\\.work$/"],
      "matchStrings": ["(^|\\n)go (?<currentValue>[\\d.]+)\\s*(\\n|$)"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version",
      "versioningTemplate": "go-mod-directive"
    },
    {
      "customType": "regex",
      "description": "Track the Cloudflare Pages Node version alongside mise",
      "managerFilePatterns": ["/^infra\\/website\\.ts$/"],
      "matchStrings": ["const PAGES_NODE_VERSION = '(?<currentValue>[\\d.]+)';"],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "description": "Track annotated HelmChart versions",
      "managerFilePatterns": ["/^(?:apps|k3s)/.+\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+) registryUrl=(?<registryUrl>\\S+)\\s+version:\\s*(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["helm"],
      "groupName": "helm charts"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["pandoks/charts/**"],
      "groupName": "helm charts",
      "pinDigests": false
    },
    {
      "description": "Keep kubectl updates separate because KUBECTL_SHA256 must be updated manually.",
      "matchDepNames": ["kubectl"],
      "groupName": "kubectl"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"]
  }
}
