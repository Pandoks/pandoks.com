{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":semanticCommits", "group:allNonMajor", "group:allDigest"],
  "labels": ["dependencies"],
  "assignees": ["pandoks"],
  "minimumReleaseAge": "7 days",
  "dependencyDashboardTitle": "[renovate] 🤖 outdated dependencies",
  "dependencyDashboardLabels": ["dependencies"],
  "dependencyDashboardAutoclose": false,
  "dependencyDashboardOSVVulnerabilitySummary": "unresolved",
  "osvVulnerabilityAlerts": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0,
  "rangeStrategy": "pin",
  "postUpdateOptions": ["pnpmDedupe", "gomodTidy"],
  "customDatasources": {
    "chromium-stable": {
      "description": "Chrome stable channel for Linux, queried from Google's official version history API. Returns the latest stable Chromium version (e.g. 148.0.7778.215). Used to keep packages/stealth-chromium/chromium_version.txt in sync with upstream releases.",
      "defaultRegistryUrlTemplate": "https://versionhistory.googleapis.com/v1/chrome/platforms/linux/channels/stable/versions",
      "format": "json",
      "transformTemplates": [
        "{\"releases\": $map(versions, function($v) { {\"version\": $v.version} })}"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track Chromium stable releases. The version in packages/stealth-chromium/chromium_version.txt is the pin used by setup.sh + build.sh. Renovate polls Google's version history API and opens a PR when stable advances. The build pipeline runs automatically on PR merge via .github/workflows/build-chromium.yaml.",
      "managerFilePatterns": ["/(^|/)packages/stealth-chromium/chromium_version\\.txt$/"],
      "matchStrings": ["^(?<currentValue>\\d+\\.\\d+\\.\\d+\\.\\d+)\\s*$"],
      "depNameTemplate": "chromium",
      "packageNameTemplate": "chromium",
      "datasourceTemplate": "custom.chromium-stable",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Sync the `go` directive in go.work when go.mod is bumped (Renovate's gomod manager only handles go.mod)",
      "managerFilePatterns": ["/(^|/)go\\.work$/"],
      "matchStrings": ["(^|\\n)go (?<currentValue>[\\d.]+)\\s*(\\n|$)"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version",
      "versioningTemplate": "go-mod-directive"
    },
    {
      "customType": "regex",
      "description": "Track kubectl version in the argocd image (binary fetched from dl.k8s.io). KUBECTL_SHA256 must be updated by hand on each bump — Renovate cannot compute binary checksums.",
      "managerFilePatterns": ["/(^|/)packages/argocd/Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) packageName=(?<packageName>[^\\s]+)\\s+ARG KUBECTL_VERSION=(?<currentValue>v[\\d.]+)"
      ],
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Bump `version:` pins annotated with a trailing `# renovate: datasource=... packageName=...` comment.",
      "managerFilePatterns": ["/^apps/.+/kube/.+\\.ya?ml$/"],
      "matchStrings": [
        "version:\\s*(?<currentValue>\\S+)\\s*#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+)\\s+packageName=(?<packageName>[^\\s]+)"
      ],
      "registryUrlTemplate": "https://ghcr.io",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["helm-values", "helmv3"],
      "groupName": "helm charts"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "schedule": ["at any time"]
  }
}
