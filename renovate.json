{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":semanticCommits", "group:allNonMajor", "group:allDigest"],
  "labels": ["dependencies"],
  "assignees": ["pandoks"],
  "minimumReleaseAge": "7 days",
  "dependencyDashboardTitle": "[renovate] 🤖 outdated dependencies (DON'T DELETE)",
  "dependencyDashboardLabels": ["dependencies"],
  "dependencyDashboardAutoclose": false,
  "dependencyDashboardOSVVulnerabilitySummary": "unresolved",
  "osvVulnerabilityAlerts": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0,
  "rangeStrategy": "pin",
  "postUpdateOptions": ["pnpmDedupe", "gomodTidy"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Sync the `go` directive in go.work when go.mod is bumped (Renovate's gomod manager only handles go.mod)",
      "managerFilePatterns": ["/(^|/)go\\.work$/"],
      "matchStrings": ["(^|\\n)go (?<currentValue>[\\d.]+)\\s*(\\n|$)"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version",
      "versioningTemplate": "go-mod-directive"
    },
    {
      "customType": "regex",
      "description": "Track kubectl version in the argocd image (binary fetched from dl.k8s.io). KUBECTL_SHA256 must be updated by hand on each bump — Renovate cannot compute binary checksums, and the stale SHA fails the argocd image build on the PR branch until fixed.",
      "managerFilePatterns": ["/(^|/)packages/argocd/Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) packageName=(?<packageName>[^\\s]+)\\s+ARG KUBECTL_VERSION=(?<currentValue>v[\\d.]+)"
      ],
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Bump `version:` pins annotated with a trailing `# renovate: datasource=... packageName=...` comment.",
      "managerFilePatterns": ["/^apps/.+/kube/.+\\.ya?ml$/"],
      "matchStrings": [
        "version:\\s*(?<currentValue>\\S+)\\s*#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+)\\s+packageName=(?<packageName>[^\\s]+)"
      ],
      "registryUrlTemplate": "https://ghcr.io",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Track the Cloudflare Pages Node version alongside mise",
      "managerFilePatterns": ["/^infra\\/website\\.ts$/"],
      "matchStrings": ["const PAGES_NODE_VERSION = '(?<currentValue>[\\d.]+)';"],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version",
      "versioningTemplate": "node"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["helm-values", "helmv3"],
      "groupName": "helm charts"
    },
    {
      "description": "Group all kubectl pins into one PR — kubectl's depNames differ across managers so copies don't auto-coalesce, and the bump needs a manual KUBECTL_SHA256 edit that shouldn't block the all-minor-patch group.",
      "matchDepNames": ["kubectl", "kubernetes/kubernetes"],
      "groupName": "kubectl"
    },
    {
      "description": "Update the mise and Cloudflare Pages Node pins together",
      "matchDatasources": ["node-version"],
      "matchDepNames": ["node"],
      "matchFileNames": ["mise.toml", "infra/website.ts"],
      "groupName": "Node.js runtime",
      "minimumGroupSize": 2
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "schedule": ["at any time"]
  }
}
