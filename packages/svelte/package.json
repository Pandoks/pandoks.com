{
  "name": "@pandoks.com/svelte",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "portless run --name svelte-preview vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "shadcn": "pnpm dlx shadcn-svelte@latest add"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./shadcn/*": "./src/lib/components/ui/*/index.js",
    "./shadcn/css": "./src/app.css",
    "./styles/*": "./src/lib/styles/*.css",
    "./svg/*": "./src/lib/svg/*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.16.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "jsdom": "^29.1.1",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
