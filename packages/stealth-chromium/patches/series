webgl-unmasked-strings.patch
canvas-getimagedata-noise.patch
canvas-todataurl-noise.patch
audio-buffer-noise.patch
fontaccess-enumeration.patch

# --- network / leak prevention ---
webrtc-no-ip-leak.patch

# --- automation-protocol leak (V8 inspector) ---
v8-cdp-inspector-leak.patch

# --- device / sensor API realism ---
mediadevices-enumerate.patch
speechsynthesis-voices.patch

# --- font availability consistency ---
fontcache-availability.patch
