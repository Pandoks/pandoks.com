# apex patch: spoof navigator.userAgentData.platform (UA Client Hints)
#
# navigator.userAgentData.platform, getHighEntropyValues({platform}), and
# userAgentData.toJSON() all read the same NavigatorUAData::platform_ member.
# Patching SetPlatform() -- where platform_ is written once -- keeps all three
# JS surfaces consistent. (Overriding platform() alone would desync it from
# getHighEntropyValues, an exploitable inconsistency.)
#
# Reads APEX_FP_UA_PLATFORM (e.g. "macOS", "Windows"); falls through to the
# embedder-supplied value when unset.
#
# Apply target: third_party/blink/renderer/core/frame/navigator_ua_data.cc
--- a/third_party/blink/renderer/core/frame/navigator_ua_data.cc
+++ b/third_party/blink/renderer/core/frame/navigator_ua_data.cc
@@ -1,3 +1,5 @@
+#include "apex_fingerprint.h"
+
 // Copyright 2020 The Chromium Authors
 // Use of this source code is governed by a BSD-style license that can be
 // found in the LICENSE file.
@@ NavigatorUAData::SetPlatform @@
 void NavigatorUAData::SetPlatform(const String& brand, const String& version) {
-  platform_ = brand;
-  platform_version_ = version;
+  if (apex_fp::HasOverride("APEX_FP_UA_PLATFORM")) {
+    platform_ = String::FromUTF8(apex_fp::EnvStr("APEX_FP_UA_PLATFORM"));
+  } else {
+    platform_ = brand;
+  }
+  platform_version_ = version;
 }
