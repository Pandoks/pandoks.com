# apex patch: give speechSynthesis.getVoices() a realistic voice list
#
# THE PROBLEM. An empty speechSynthesis voice list is a strong headless tell --
# every real desktop ships TTS voices. A containerized Chrome with no speech
# engine returns nothing from getVoices().
#
# THE FIX. OnSetVoiceList() receives the voice list as a Vector of mojom
# SpeechSynthesisVoicePtr. When APEX_FP_ACTIVE is set and that vector is empty,
# we fill it with a realistic, OS-consistent set (macOS voices for a macOS
# persona, Windows voices for a Windows persona -- keyed off APEX_FP_UA_PLATFORM)
# BEFORE the upstream code converts it into SpeechSynthesisVoice objects. So the
# rest of OnSetVoiceList runs unchanged and getVoices() returns a populated,
# coherent list.
#
# Apply target: third_party/blink/renderer/modules/speech/speech_synthesis.cc
--- a/third_party/blink/renderer/modules/speech/speech_synthesis.cc
+++ b/third_party/blink/renderer/modules/speech/speech_synthesis.cc
@@ -1,3 +1,5 @@
+#include "third_party/blink/renderer/modules/speech/apex_voices.h"
+
 // Copyright 2013 The Chromium Authors
 // Use of this source code is governed by a BSD-style license that can be
 // found in the LICENSE file.
@@ SpeechSynthesis::OnSetVoiceList @@
 void SpeechSynthesis::OnSetVoiceList(
     Vector<mojom::blink::SpeechSynthesisVoicePtr> mojom_voices) {
+  // --- apex: ensure a realistic OS-consistent voice list ---
+  // Fills mojom_voices in place if it arrived empty (headless with no TTS
+  // engine). The conversion loop below then runs over the filled vector.
+  apex_fp::EnsureRealisticVoiceList(&mojom_voices);
+  // --- end apex ---
   voice_list_.clear();
