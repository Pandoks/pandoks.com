# apex patch: deterministic per-session noise on AudioBuffer channel data
#
# getChannelData() returns a live VIEW onto the channel buffer, so perturbing it
# there would (a) be non-deterministic across repeated calls and (b) risk
# audible artifacts. Instead we perturb each channel ONCE, in AudioBuffer's
# CreateFromAudioBus path -- the point where rendered audio (e.g. the output of
# an OfflineAudioContext, which is what audio fingerprinters hash) is copied
# into the AudioBuffer's DOMFloat32Arrays.
#
# This keeps getChannelData() itself completely unpatched -- a fingerprinter
# inspecting getChannelData.toString() sees pristine native code.
#
# Apply target: third_party/blink/renderer/modules/webaudio/audio_buffer.cc
--- a/third_party/blink/renderer/modules/webaudio/audio_buffer.cc
+++ b/third_party/blink/renderer/modules/webaudio/audio_buffer.cc
@@ -1,3 +1,5 @@
+#include "third_party/blink/renderer/modules/webaudio/apex_audio_noise.h"
+
 // Copyright 2010 The Chromium Authors
 // Use of this source code is governed by a BSD-style license that can be
 // found in the LICENSE file.
@@ AudioBuffer::CreateFromAudioBus / channel copy loop @@
   // <upstream> copies each channel of `audio_bus` into channels_[i]. apex
   // perturbs each channel buffer once, right after it is populated.
   for (unsigned i = 0; i < number_of_channels; ++i) {
     memcpy(channels_[i]->Data(), audio_bus->Channel(i)->Data(),
            length * sizeof(float));
+    // --- apex audio-noise injection ---
+    if (apex_fp::Active()) {
+      apex_fp::PerturbAudioChannel(
+          static_cast<float*>(channels_[i]->Data()), length, i);
+    }
+    // --- end apex ---
   }
