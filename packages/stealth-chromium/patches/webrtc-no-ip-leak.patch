# apex patch: stop WebRTC from leaking the real IP past a proxy
#
# THE PROBLEM. RTCPeerConnection opens its own UDP sockets for ICE/STUN. Those
# sockets bypass an HTTP/SOCKS proxy entirely -- a STUN request goes out on the
# real network interface and the server-reflexive candidate returns the real
# public IP. Host candidates additionally expose the LAN IP. So one line of JS
# on any page (`new RTCPeerConnection(...)`) de-anonymizes a proxied browser.
#
# THE FIX. Chromium already has a policy enum that controls this:
#   kDisableNonProxiedUdp -> enable_nonproxied_udp = false, no host candidates.
# This is a REAL, valid Chrome configuration (enterprise policy sets it), so
# forcing it is not itself a fingerprint -- unlike disabling WebRTC entirely.
# When APEX_FP_ACTIVE is set we force that branch regardless of the user pref,
# so WebRTC can only use proxied/relayed transport. No host candidate, no
# server-reflexive leak on the real interface.
#
# This keeps WebRTC FUNCTIONAL (TURN-relayed connections still work) -- it just
# cannot emit a candidate that reveals the real network. The ICE candidate
# `foundation` therefore stays a correct CRC32 of only proxied addresses: no
# fake-foundation tell.
#
# Apply target: third_party/blink/renderer/modules/peerconnection/peer_connection_dependency_factory.cc
--- a/third_party/blink/renderer/modules/peerconnection/peer_connection_dependency_factory.cc
+++ b/third_party/blink/renderer/modules/peerconnection/peer_connection_dependency_factory.cc
@@ -1,3 +1,5 @@
+#include "apex_fingerprint.h"
+
 // Copyright 2014 The Chromium Authors
 // Use of this source code is governed by a BSD-style license that can be
 // found in the LICENSE file.
@@ CreatePortAllocator: WebRTC IP handling policy switch @@
   switch (webrtc_ip_handling_policy) {
+    // --- apex: force no-non-proxied-UDP so the real IP cannot leak ---
+    // (placed first so it wins regardless of the resolved policy value)
+    default:
+      if (apex_fp::Active()) {
+        port_config.enable_multiple_routes = false;
+        port_config.enable_nonproxied_udp = false;
+        port_config.enable_default_local_candidate = false;
+        break;
+      }
+      [[fallthrough]];
+    // --- end apex ---
     case mojo::blink::WebRtcIpHandlingPolicy::kDefaultPublicInterfaceOnly:
     case mojo::blink::WebRtcIpHandlingPolicy::
         kDefaultPublicAndPrivateInterfaces:
       port_config.enable_multiple_routes = false;
       port_config.enable_nonproxied_udp = true;
       port_config.enable_default_local_candidate =
           (webrtc_ip_handling_policy ==
            mojo::blink::WebRtcIpHandlingPolicy::
                kDefaultPublicAndPrivateInterfaces);
       break;
     case mojo::blink::WebRtcIpHandlingPolicy::kDisableNonProxiedUdp:
       port_config.enable_multiple_routes = false;
       port_config.enable_nonproxied_udp = false;
       break;
     case mojo::blink::WebRtcIpHandlingPolicy::kDefault:
       port_config.enable_multiple_routes = true;
       port_config.enable_nonproxied_udp = true;
       break;
   }
