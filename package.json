{
  "name": "pandoks.com",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "type": "module",
  "scripts": {
    "sso": "aws sso login --sso-session=Pandoks_ --use-device-code --no-browser",
    "cluster": "./scripts/cluster/main.sh",
    "dev": "sst dev",
    "dev:init": "pnpm cluster k3d deps up && pnpm cluster k3d up && pnpm docker:build && pnpm dev:push && pnpm cluster deploy dev --bootstrap && pnpm cluster deploy dev",
    "dev:destroy": "pnpm cluster k3d down && pnpm cluster k3d deps down",
    "dev:push": "pnpm -r dev:push",
    "docker:build": "pnpm -r docker:build",
    "shadcn": "pnpm dlx shadcn-svelte@latest add $@ -c packages/svelte",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "devDependencies": {
    "glob": "^13.0.6",
    "json-stringify-pretty-compact": "^4.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "sst": "^4.1.8"
  }
}
