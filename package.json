{
  "name": "pandoks.com",
  "version": "1.0.0",
  "packageManager": "pnpm@11.2.2+sha512.NuZiH61QYXiTZFXnAke4gI707CV5ep9DepMoGgIEhOJgf2pGmiLpgph8PbuIZuMHFRSrEKShdJ4G7c0ewRhDbw==",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "sso": "aws sso login --sso-session=Pandoks_ --use-device-code --no-browser",
    "cluster": "./scripts/cluster/main.sh",
    "dev": "sst dev",
    "dev:init": "pnpm cluster k3d deps up && pnpm cluster k3d up && pnpm docker:build && pnpm dev:push && pnpm cluster deploy dev --bootstrap && pnpm cluster deploy dev",
    "dev:destroy": "pnpm cluster k3d down && pnpm cluster k3d deps down",
    "dev:push": "pnpm -r --if-present dev:push",
    "docker:build": "pnpm -r --if-present docker:build",
    "shadcn": "pnpm dlx shadcn-svelte@latest add -c packages/svelte",
    "format": "./scripts/format/main.sh",
    "lint": "./scripts/lint/main.sh",
    "fix": "./scripts/fix/main.sh",
    "check:infra": "tsc -p .",
    "check": "pnpm -r --if-present check && pnpm check:infra",
    "postinstall": "sst install"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "json-stringify-pretty-compact": "^4.0.0",
    "portless": "^0.13.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte-eslint-parser": "^1.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "dependencies": {
    "sst": "^4.14.3"
  }
}
