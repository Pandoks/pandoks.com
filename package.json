{
  "name": "pandoks.com",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "type": "module",
  "scripts": {
    "sso": "aws sso login --sso-session=Pandoks_ --use-device-code --no-browser",
    "cluster": "./scripts/cluster/main.sh",
    "dev": "sst dev",
    "dev:init": "pnpm run cluster k3d deps up && pnpm run cluster k3d up && pnpm run docker:build && pnpm run dev:push && pnpm run cluster deploy dev --bootstrap && pnpm run cluster deploy dev",
    "dev:destroy": "pnpm run cluster k3d down && pnpm run cluster k3d deps down",
    "dev:push": "pnpm -r run dev:push",
    "docker:build": "pnpm -r run docker:build",
    "shadcn": "pnpm dlx shadcn-svelte@latest add $@ -c packages/svelte",
    "clean": "pnpm -r run clean",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "devDependencies": {
    "glob": "^13.0.6",
    "json-stringify-pretty-compact": "^4.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "sst": "^4.7.4"
  },
  "pnpm": {
    "//TODO": "remove overrides once fonteditor-core, plist, and axios update their deps to non-vulnerable versions",
    "overrides": {
      "follow-redirects": ">=1.16.0",
      "@xmldom/xmldom": ">=0.9.9"
    }
  }
}
