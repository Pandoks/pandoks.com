{
  "name": "pandoks.com",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "type": "module",
  "scripts": {
    "sso": "aws sso login --sso-session=Pandoks_ --use-device-code --no-browser",
    "cluster": "./scripts/cluster/main.sh",
    "dev": "sst dev",
    "dev:init": "pnpm cluster k3d deps up && pnpm cluster k3d up && pnpm docker:build && pnpm dev:push && pnpm cluster deploy dev --bootstrap && pnpm cluster deploy dev",
    "dev:destroy": "pnpm cluster k3d down && pnpm cluster k3d deps down",
    "dev:push": "pnpm -r --if-present dev:push",
    "docker:build": "pnpm -r --if-present docker:build",
    "shadcn": "pnpm dlx shadcn-svelte@latest add -c packages/svelte",
    "format:js": "prettier --write .",
    "format:go": "golangci-lint fmt",
    "format": "pnpm run '/^format:(?!check)/'",
    "format:check:js": "prettier --check .",
    "format:check:go": "golangci-lint fmt --diff",
    "format:check": "pnpm run /^format:check:/",
    "lint:js": "eslint .",
    "lint:go": "golangci-lint run $(go list -m -f '{{.Dir}}/...')",
    "lint": "pnpm run /^lint:/",
    "fix:js": "eslint . --fix",
    "fix:go": "golangci-lint run --fix $(go list -m -f '{{.Dir}}/...')",
    "fix": "pnpm run /^fix:/",
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@types/node": "^22.9.0",
    "eslint": "^9.20.0",
    "eslint-plugin-svelte": "^3.0.0",
    "eslint-plugin-unicorn": "^57.0.0",
    "globals": "^15.14.0",
    "glob": "^13.0.6",
    "jiti": "^2.4.2",
    "json-stringify-pretty-compact": "^4.0.0",
    "portless": "^0.11.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte-eslint-parser": "^1.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.24.0"
  },
  "dependencies": {
    "sst": "^4.7.5"
  },
  "pnpm": {
    "//TODO": "remove override when upstream bumps its pinned dep — follow-redirects: axios; @xmldom/xmldom: fonteditor-core + plist; undici: jsdom; fast-xml-parser: @aws-sdk/xml-builder; devalue: svelte; lodash: @electron-forge; picomatch: anymatch + @rollup/pluginutils; tar: @electron/node-gyp; cookie: @sveltejs/kit; tmp: external-editor; @tootallnate/once: http-proxy-agent; axios: twilio",
    "overrides": {
      "follow-redirects": "^1.16.0",
      "@xmldom/xmldom": "^0.9.9",
      "undici": "^7.24.0",
      "fast-xml-parser": "^5.6.0",
      "devalue": "^5.7.1",
      "lodash": "^4.18.1",
      "picomatch": "^4.0.4",
      "tar": "^7.5.13",
      "cookie": "~0.7.0",
      "tmp": "^0.2.5",
      "@tootallnate/once": "^3.0.1",
      "axios": "^1.15.0"
    }
  }
}
